---
// FindingCard — server-rendered presentation of a single finding.
// Currently unused at runtime: the /findings/ page builds DOM
// client-side in findings-app.js. Shipped as forward-compat for any
// future SSG fetch path and as a typed reference next to api.ts.
import { formatRelativeTime } from '../lib/api';

export interface Props {
  unit_id: string;
  title: string;
  domain: string[];
  last_confirmed_at: string | null;
  status: string;
}

const { unit_id, title, domain, last_confirmed_at, status } = Astro.props;
const relTime = formatRelativeTime(last_confirmed_at);
---
<article class="info-box info-box--success finding-card" data-unit-id={unit_id}>
  <span class="info-box__icon" aria-hidden="true">
    <svg viewBox="0 0 20 20" width="20" height="20" fill="currentColor" focusable="false">
      <path d="M16.704 5.29a1 1 0 0 1 0 1.42l-7.99 7.99a1 1 0 0 1-1.42 0L3.296 10.7a1 1 0 1 1 1.42-1.42l3.286 3.286 7.282-7.276a1 1 0 0 1 1.42 0z"/>
    </svg>
  </span>
  <div class="info-box__body">
    <h3 class="finding-card__title">{title}</h3>
    {domain.length > 0 && (
      <ul class="finding-card__domains" aria-label="Domain tags">
        {domain.map((d) => <li class="domain-pill">{d}</li>)}
      </ul>
    )}
    {relTime && (
      <p class="finding-card__time">
        <span class="finding-card__status">{status}</span>
        {' · '}
        <time datetime={last_confirmed_at ?? ''}>{relTime}</time>
      </p>
    )}
  </div>
</article>
