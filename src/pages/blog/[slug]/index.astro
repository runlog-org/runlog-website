---
import Base from '../../../layouts/Base.astro';
import Crumbs from '../../../components/Crumbs.astro';
import { SITE_URL, breadcrumbList, blogPosting, isoDate } from '../../../lib/schema';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'blog'> };
const { post } = Astro.props as Props;
const { Content } = await render(post);

const url = `${SITE_URL}/blog/${post.id}/`;
const headline = post.data.headline ?? post.data.title;
const datePublished = isoDate(post.data.pubDate);

const graph = [
  breadcrumbList([
    { name: 'Runlog', url: `${SITE_URL}/` },
    { name: 'Blog', url: `${SITE_URL}/blog/` },
    { name: headline, url },
  ]),
  blogPosting({
    url,
    headline,
    description: post.data.description,
    datePublished,
  }),
];
---
<Base
  title={`${post.data.title} — Runlog`}
  description={post.data.description}
  canonical={url}
  ogType="article"
  ogTitle={headline}
  ogDescription={post.data.description}
  twitterTitle={headline}
  twitterDescription={post.data.description}
  articlePublishedTime={datePublished}
  graph={graph}
>
  <Crumbs slot="crumbs" href="/blog/" label="Blog" />

  <article>
    <Content />
  </article>
</Base>
