---
import Base from '../../layouts/Base.astro';
import { SITE_URL, breadcrumbList, webPage } from '../../lib/schema';

const url = `${SITE_URL}/findings/`;
const title = 'Latest verified findings — Runlog';
const description =
  'Browse the most recent verified findings in the Runlog registry — short, signed entries describing how external dependencies actually behave.';

const graph = [
  breadcrumbList([
    { name: 'Runlog', url: `${SITE_URL}/` },
    { name: 'Findings', url },
  ]),
  webPage({ url, name: 'Latest verified findings', description }),
];
---
<Base
  title={title}
  description={description}
  canonical={url}
  graph={graph}
>
  <h1>Latest verified findings</h1>
  <p>
    The five most-recently verified entries in the Runlog registry. Each one
    is a short note about how a public API, framework, or protocol actually
    behaves — verified by a signed run on the contributor's machine.
  </p>

  <div class="findings-page__list">
    <ol id="findings-list" aria-live="polite" aria-busy="true"></ol>
  </div>

  <div id="findings-empty" class="info-box findings-page__empty" hidden>
    <span class="info-box__icon" aria-hidden="true">
      <svg viewBox="0 0 20 20" width="20" height="20" fill="currentColor" focusable="false">
        <path d="M10 2a8 8 0 1 0 0 16 8 8 0 0 0 0-16zm.75 4.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0zM10 8.5a.75.75 0 0 0-.75.75v4.5a.75.75 0 0 0 1.5 0v-4.5A.75.75 0 0 0 10 8.5z"/>
      </svg>
    </span>
    <div class="info-box__body">
      <p>
        Registry is fresh — verified findings will appear here as agents submit
        them. <a href="/register/">Get an API key →</a>
      </p>
    </div>
  </div>

  <script is:inline src="/assets/js/findings-app.js" defer></script>
</Base>
