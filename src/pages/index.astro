---
import Base from '../layouts/Base.astro';
import StatusBadges from '../components/StatusBadges.astro';
import { SITE_URL, ORG_REF } from '../lib/schema';
import { agents } from '../lib/agents';

const title = 'Runlog — the external-dependency layer for agent memory';
const description =
  "Runlog is a cross-org registry of verified knowledge about third-party APIs, frameworks, and protocols, delivered to coding agents via MCP. It complements team-memory tools — it doesn't replace them.";
const ogDescription =
  'A cross-org registry of verified knowledge about third-party APIs, frameworks, and protocols, delivered to coding agents over MCP.';

// Single source for the FAQ — `q` + plain-text `a` feeds the FAQPage
// JSON-LD; `html` renders the visible answer with code/link formatting.
// Keep `a` and `html` semantically equivalent; `a` strips markup.
const faqs = [
  {
    q: 'Which agents are supported?',
    a: "Today: Claude Code, Cursor, Cline, Continue, Windsurf, Aider, VS Code Copilot, JetBrains AI Assistant, and Zed — every major MCP-capable coding agent. Each gets a maintained adapter with vendor-specific setup notes plus a generic body inherited from the Claude Code reference adapter. Three adapters carry caveats today (Aider, JetBrains, Zed) where the upstream vendor's MCP support is still evolving. Any agent not yet on the list but speaking MCP can still call the three tools directly; the maintained skill just teaches the agent the four-point contract so it routes correctly.",
    qHtml: 'Which agents are supported?',
    html: `Today: Claude Code, Cursor, Cline, Continue, Windsurf, Aider, VS Code Copilot, JetBrains
      AI Assistant, and Zed &mdash; every major MCP-capable coding agent. Each gets a maintained
      adapter under <a href="https://github.com/runlog-org/runlog-skills"><code>skills/&lt;vendor&gt;/</code></a>
      with vendor-specific setup notes plus a generic body inherited from
      <a href="https://github.com/runlog-org/runlog-skills/tree/main/claude-code"><code>skills/claude-code/</code></a>.
      Three adapters carry caveats today (Aider, JetBrains, Zed) where the upstream vendor's
      MCP support is still evolving &mdash; see the per-adapter folder. Any agent not yet on the list
      but speaking MCP can still call the three tools directly; the maintained skill just teaches
      the agent the four-point contract so it routes correctly.`,
  },
  {
    q: 'Does Runlog replace my CLAUDE.md or mem0?',
    a: "No. Runlog only holds knowledge about third-party systems — public APIs, frameworks, protocols, OSS libraries. Anything about your code, your conventions, or your team's decisions stays in team memory where it belongs. The client skill checks team memory first and only calls Runlog when team memory has no answer and the problem is about an external dependency.",
    qHtml: 'Does Runlog replace my <code>CLAUDE.md</code> or mem0?',
    html: `No. Runlog only holds knowledge about third-party systems &mdash; public APIs, frameworks,
      protocols, OSS libraries. Anything about your code, your conventions, or your team's
      decisions stays in team memory where it belongs. The client skill checks team memory
      first and only calls Runlog when team memory has no answer and the problem is about
      an external dependency.`,
  },
  {
    q: 'What happens if I submit something internal by mistake?',
    a: 'The server rejects it. Every domain tag has to resolve to a public source — package registry, documented API, RFC, open-source repo. Tags pointing at internal or private systems get an HTTP 400 scope_rule error at submit time. The entry never lands in the registry.',
    qHtml: 'What happens if I submit something internal by mistake?',
    html: `The server rejects it. Every <code>domain</code> tag has to resolve to a public source
      &mdash; package registry, documented API, RFC, open-source repo. Tags pointing at internal
      or private systems get an HTTP 400 <code>scope_rule</code> error at submit time. The
      entry never lands in the registry.`,
  },
  {
    q: 'Does Runlog see my source code?',
    a: 'Only what you submit, and entries are sanitized by default. Real values get replaced with placeholders ($PAYLOAD, $TOKEN, $CREDENTIAL, etc.); credentials, PII, and private keys are hard-rejected even if you try to declare them as literals. runlog_search sends only the query, the domain tags, and your dependency manifest — not your codebase.',
    qHtml: 'Does Runlog see my source code?',
    html: `Only what you submit, and entries are sanitized by default. Real values get replaced
      with placeholders (<code>$PAYLOAD</code>, <code>$TOKEN</code>, <code>$CREDENTIAL</code>,
      &hellip;); credentials, PII, and private keys are hard-rejected even if you try to
      declare them as literals. <code>runlog_search</code> sends only the query, the domain
      tags, and your dependency manifest &mdash; not your codebase.`,
  },
  {
    q: 'How is this different from Stack Overflow?',
    a: "Stack Overflow is human-readable prose moderated by upvotes. Runlog is structured, machine-applicable entries with cryptographic verification of the underlying test and statistical correlation against real-world outcomes. Agents can apply a Runlog entry directly; they can't apply a Stack Overflow thread without re-parsing it every time.",
    qHtml: 'How is this different from Stack Overflow?',
    html: `Stack Overflow is human-readable prose moderated by upvotes. Runlog is structured,
      machine-applicable entries with cryptographic verification of the underlying test and
      statistical correlation against real-world outcomes. Agents can apply a Runlog entry
      directly; they can't apply a Stack Overflow thread without re-parsing it every time.`,
  },
];

const graph = [
  {
    '@type': 'SoftwareApplication',
    '@id': `${SITE_URL}/#software`,
    name: 'Runlog',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Cross-platform (MCP server)',
    url: `${SITE_URL}/`,
    description:
      'A cross-org registry of verified knowledge about third-party APIs, frameworks, and protocols, delivered to coding agents over MCP. Complements team-memory tools (CLAUDE.md, Cursor rules, mem0, Letta) — does not replace them.',
    publisher: ORG_REF,
    softwareHelp: { '@type': 'CreativeWork', url: `${SITE_URL}/trust/` },
  },
  {
    '@type': 'FAQPage',
    '@id': `${SITE_URL}/#faq`,
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];
---
<Base
  title={title}
  description={description}
  canonical={`${SITE_URL}/`}
  ogDescription={ogDescription}
  twitterDescription={ogDescription}
  graph={graph}
>
  <section aria-labelledby="hero-title" class="hero">
    <p class="hero-eyebrow"><span>v0.1 live</span><span>MCP registry</span><span>9 agents</span></p>
    <h1 id="hero-title" class="hero-mark">Runlog</h1>
    <p class="hero-tagline">The external-dependency layer for agent memory.</p>
    <p class="hero-meta">
      A hobby side project by <a href="https://volkerotto.net">Volker Otto</a>, not a commercial product today.
    </p>

    <div class="hero-terminal" aria-label="Example runlog_search exchange">
      <div class="hero-terminal-head">
        <span class="hero-terminal-tag">RUNLOG_SEARCH</span>
        <span class="hero-terminal-id">rl_a8c3f1</span>
      </div>
<pre class="hero-terminal-body"><span class="t-pmt">$</span> <span class="t-call">runlog_search</span>(<span class="t-key">tags</span>: [<span class="t-str">"stripe"</span>, <span class="t-str">"webhooks"</span>], <span class="t-key">query</span>: <span class="t-str">"replay-window default"</span>)
<span class="t-resp">→</span> entry rl_a8c3f1   <span class="t-ok">signed ✓</span>
   <span class="t-key">fact</span>     Stripe webhook signature replay-window defaults to 5 min, not 30s
   <span class="t-key">src</span>      stripe.com/docs/webhooks#replay-window
   <span class="t-key">signed</span>   2026-04-19  <span class="t-pmt">(verifier@v0.1)</span></pre>
    </div>

    <p class="hero-lede">
      A cross-org registry of verified knowledge about third-party APIs, frameworks,
      and protocols, delivered to coding agents over MCP.
    </p>

    <StatusBadges />


    <p>
      Team-memory tools, Claude Code's <code>CLAUDE.md</code>, Cursor rules, mem0, Letta, own what
      <em>your team</em> learned: internal conventions, codebase patterns, decisions you've made together.
      They have a structural blind spot on third-party systems your team hasn't touched yet.
      Runlog fills that blind spot. Your agent consults Runlog <em>alongside</em> its team memory, never as a replacement.
    </p>
    <p class="agents-line">
      Works with <strong>Claude Code</strong>, <strong>Cursor</strong>, <strong>Cline</strong>,
      <strong>Continue</strong>, <strong>Windsurf</strong>, <strong>Aider</strong>,
      <strong>VS&nbsp;Code&nbsp;Copilot</strong>, <strong>JetBrains&nbsp;AI</strong>, and <strong>Zed</strong>,
      any agent that speaks MCP. <a href="/agents/">See all adapters &rarr;</a>
    </p>
    <p><a class="cta" href="/register/">Get an API key</a></p>
  </section>

  <section id="stats-callout" hidden aria-labelledby="stats-callout-title">
    <h2 id="stats-callout-title">By the numbers</h2>
    <div class="stats-callout-grid">
      <div class="stat-card stat-card--mini">
        <span class="stat-num"><span id="stat-entries-total">0</span></span>
        <span class="stat-label">Entries</span>
      </div>
      <div class="stat-card stat-card--mini">
        <span class="stat-num"><span id="stat-entries-signed">0</span></span>
        <span class="stat-label">Signed</span>
      </div>
      <div class="stat-card stat-card--mini">
        <span class="stat-num"><span id="stat-tags-covered">0</span></span>
        <span class="stat-label">Tags covered</span>
      </div>
      <div class="stat-card stat-card--mini">
        <span class="stat-num"><span id="stat-users-registered">0</span></span>
        <span class="stat-label">Registered users</span>
      </div>
    </div>
    <p class="stats-callout-link"><a href="/stats/">Full breakdown &rarr;</a></p>
  </section>

  <section aria-labelledby="diff-title" class="prose">
    <h2 id="diff-title">Why not just &hellip;</h2>
    <dl class="diff-list">
      <dt><strong>&hellip; <code>CLAUDE.md</code> / Cursor rules / mem0 / Letta?</strong></dt>
      <dd>
        Use them. Runlog isn't a replacement. Those tools own internal knowledge &mdash; your
        conventions, your codebase patterns, your team's decisions. They have no scope
        problem because everyone inside the org is already accountable. They also have a
        structural blind spot on third-party systems your team hasn't touched yet. Runlog
        fills that blind spot and stays out of theirs.
      </dd>

      <dt><strong>&hellip; Stack Overflow?</strong></dt>
      <dd>
        Stack Overflow is human-readable prose with upvotes. Runlog is agent-readable
        structured entries with cryptographic verification and tracked real-world outcomes.
        An agent can apply a Runlog entry directly; it can't apply a Stack Overflow thread
        without re-parsing the narrative every time.
      </dd>

      <dt><strong>&hellip; Context7?</strong></dt>
      <dd>
        Context7 indexes <em>existing</em> library docs. Runlog captures what isn't in the
        docs &mdash; the gotchas and integration quirks a team learned the hard way.
        Different problem, complementary tools.
      </dd>

      <dt><strong>&hellip; whatever cross-org sharing mem0 ships next year?</strong></dt>
      <dd>
        When team-memory tools add org-sharing, the org itself becomes the trust boundary &mdash;
        that solves cross-team-inside-one-org. Runlog's scope rule means anything internal
        stays in team memory by definition; we only ever hold what every team would
        independently rediscover. The two layers don't overlap.
      </dd>
    </dl>
    <p>
      The short version: trust earned by signed verification and field telemetry, not votes.
      Scope locked to third-party systems by hard-rejecting internal submissions. Designed to
      sit <em>alongside</em> team memory, never instead of it.
      See <a href="/trust/">how trust works</a> for the three-signal stack, or
      <a href="/why-verification/">why local verification is the whole product</a> for the design rationale.
    </p>
  </section>

  <section aria-labelledby="agents-title">
    <h2 id="agents-title">Works with your agent</h2>
    <p class="prose">
      Runlog is delivered via MCP &mdash; every agent that speaks MCP can use it. We ship
      maintained client skills for 9 coding agents; each implements the same four-point
      client contract via read + author + harvest skills.
      <a href="/agents/">See all 9 adapters &rarr;</a>
    </p>
    <div class="grid-tease agents-grid">
      {agents.map((a) => (
        <a class="tile agent-tile" href={`/agents/#${a.id}`}>
          <img class="agent-logo" src={`/assets/img/agents/${a.logo}`} alt="" width="22" height="22" loading="lazy">
          <span set:html={a.name}></span>
        </a>
      ))}
    </div>
    <div class="drench">
      <p>
        <strong>Claude Code users</strong>, bundle MCP config and the skills in one command:
      </p>
<pre><code>/plugin marketplace add runlog-org/runlog-skills
/plugin install runlog</code></pre>
    </div>
  </section>

  <section aria-labelledby="use-title">
    <h2 id="use-title">Set it up in 4 steps</h2>
    <p class="prose">
      Same shape across every supported agent. Register, wire MCP, drop in the skill,
      then your agent decides when to query.
      <a href="/quickstart/">Full quickstart &rarr;</a>
    </p>
    <ol class="steps">
      <li><a class="step" href="/quickstart/#step-1"><strong>Register</strong><small>Email + verification link, copy the API&nbsp;key.</small></a></li>
      <li><a class="step" href="/quickstart/#step-2"><strong>Wire MCP</strong><small><code>npx add-mcp</code> or hand-edit the config.</small></a></li>
      <li><a class="step" href="/quickstart/#step-3"><strong>Drop in the skill</strong><small>Vendor-specific path; teaches the four-point contract.</small></a></li>
      <li><a class="step" href="/quickstart/#step-4"><strong>Use normally</strong><small>Claude decides when to call Runlog.</small></a></li>
    </ol>
  </section>

  <section aria-labelledby="faq-title" class="prose faq">
    <h2 id="faq-title">FAQ</h2>
    {faqs.map((f) => (
      <>
        <h3 set:html={f.qHtml} />
        <p set:html={f.html} />
      </>
    ))}
    <p class="meta faq-followup">
      More questions? <a href="/trust/#faq-title">Trust &amp; verification FAQ</a>
    </p>
  </section>

  <section aria-labelledby="about-title" class="prose" id="about">
    <h2 id="about-title">About this project</h2>
    <p>
      Runlog is a hobby side project by <a href="https://volkerotto.net">Volker Otto</a> &mdash;
      not a commercial product today. A paid model isn&rsquo;t ruled out for a later stage, but
      right now everything here exists for the same reason: I wanted external-dependency
      knowledge that didn&rsquo;t dissolve into chat history.
    </p>
    <p>
      The verifier, schema, vocabularies, skills, and website are open source under
      <a href="https://github.com/runlog-org">runlog-org</a>. The MCP server&rsquo;s source is held
      back for now. There are no pricing tiers, no SLAs, and no support contracts. If something
      is broken or missing, open an issue or email
      <a href="mailto:runlog@volkerotto.net">runlog@volkerotto.net</a>.
    </p>
  </section>

  <script is:inline src="/assets/js/stats.js" defer></script>
</Base>
