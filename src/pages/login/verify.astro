---
import Base from '../../layouts/Base.astro';
import { pageBreadcrumb, pageUrl, webPage } from '../../lib/schema';

const url = pageUrl('login/verify');
const title = 'Confirm sign-in — Runlog';
const description =
  'Confirm your Runlog sign-in by clicking the button below. This step prevents automated scanners from consuming your one-time link.';

const graph = [
  pageBreadcrumb({ name: 'Confirm sign-in', url }),
  webPage({ url, name: 'Confirm sign-in to Runlog', description }),
];
---
<Base
  title={title}
  description={description}
  canonical={url}
  noindex
  dataNoNumber
  graph={graph}
>
  <div data-api-base="https://api.runlog.org">
    <h1>Confirm sign-in</h1>
    <p>
      Press the button below to complete sign-in. This extra step prevents
      automated email scanners from consuming your one-time link before you do.
    </p>
    <button id="confirm-btn" class="form-button" type="button">Sign in to Runlog</button>
    <div id="status" role="status" aria-live="polite"></div>
  </div>

  <script is:inline src="/assets/js/account-app.js" defer></script>
</Base>
