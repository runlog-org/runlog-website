---
import Base from '../../layouts/Base.astro';
---
<Base
  title="Verifying — Runlog"
  noindex
  dataNoNumber
>
  <div data-api-base="https://api.runlog.org">
    <h1 id="headline">Verifying your email…</h1>
    <div id="result" aria-live="polite"></div>

    <p>
      This verification step uses the token from your email to bind the issued API key
      to your account. Token retention: 24 hours; see <a href="/datenschutz/">Privacy Notice</a>.
    </p>
  </div>

  <script is:inline src="/assets/js/register-app.js" defer></script>
</Base>
