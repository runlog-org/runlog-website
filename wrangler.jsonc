{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "runlog-website",
  "main": "./dist/_worker.js/index.js",
  "compatibility_date": "2026-04-25",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  "observability": {
    "enabled": true
  }
}
